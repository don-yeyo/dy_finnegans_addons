# ==============================================
# Server Configuration
# ==============================================
PORT=5000
NODE_ENV=development

# ==============================================
# Finnegans API
# Credenciales OAuth para la API de Finnegans ERP
# ==============================================
# Client ID del servicio OAuth de Finnegans
FINNEGANS_CLIENT_ID=tu_client_id
# Client Secret del servicio OAuth de Finnegans
FINNEGANS_CLIENT_SECRET=tu_client_secret
# URL de autenticación OAuth (no cambiar salvo indicación de Finnegans)
FINNEGANS_TOKEN_URL=https://api.teamplace.finneg.com/api/oauth/token
# URL base de la API de Finnegans (no cambiar salvo indicación de Finnegans)
FINNEGANS_API_BASE=https://api.finneg.com/api
# Código de empresa en Finnegans (ej: EMPRE01)
FINNEGANS_EMPRESA_COD=EMPRE01
# Timeout en segundos para las peticiones a Finnegans
FINNEGANS_TIMEOUT=30

# Nombre del reporte de Finnegans para consultar envíos
# Configurar según el nombre del reporte creado en App Builder > Diccionario de APIs
FINNEGANS_ENVIOS_REPORT=APICONSULTAENVIOSDY
# Nombre del reporte de Finnegans para consultar hojas de ruta
FINNEGANS_HOJAS_RUTA_REPORT=APICONSULTAHOJASRUTADY

# ==============================================
# ARBA COT (Código de Operación de Traslado)
# Credenciales para el servicio de Transporte de Bienes de ARBA
# ==============================================
# Usuario del servicio COT (tramitar en arba.gov.ar)
ARBA_COT_USER=tu_usuario_arba
# Contraseña del servicio COT
ARBA_COT_PASSWORD=tu_password_arba
# URL del servicio COT
# Testing: http://cot.test.arba.gov.ar/TransporteBienes/SeguridadCliente/presentarRemitos.do
# Producción: https://cot.arba.gov.ar/TransporteBienes/SeguridadCliente/presentarRemitos.do
ARBA_COT_URL=http://cot.test.arba.gov.ar/TransporteBienes/SeguridadCliente/presentarRemitos.do
# CUIT de la empresa (sin guiones, 11 dígitos)
ARBA_CUIT_EMPRESA=30123456789
